%----------------------------------------------------------------------------------------
%	PACKAGE IDENTIFICATION
%----------------------------------------------------------------------------------------
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{dag-notes}[2023/10/27 v1.0 Custom Style for Lurie's DAG Notes]

%----------------------------------------------------------------------------------------
%	BASIC PACKAGES & GEOMETRY
%----------------------------------------------------------------------------------------
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern} % 更加清晰的字体
\RequirePackage{geometry}
\geometry{left=2.5cm, right=2.5cm, top=3cm, bottom=3cm}
\RequirePackage{fancyhdr} % 页眉页脚
\usepackage{aliascnt}
%----------------------------------------------------------------------------------------
%	MATH PACKAGES
%----------------------------------------------------------------------------------------
\RequirePackage{amsmath, amssymb, amsthm, amsfonts}
\RequirePackage{mathtools}
\RequirePackage{mathrsfs} % 花体字 \mathscr
\RequirePackage{tikz-cd}  % 交换图表，DAG笔记必备

%----------------------------------------------------------------------------------------
%	HYPERLINKS (Usually loaded last)
%----------------------------------------------------------------------------------------
\RequirePackage[hidelinks]{hyperref}

%----------------------------------------------------------------------------------------
%	THEOREM ENVIRONMENTS
%----------------------------------------------------------------------------------------
\theoremstyle{definition}

\newtheorem{definition}{Definition}[section]
\providecommand*{\definitionautorefname}{Definition}

\newaliascnt{example}{definition}
\newtheorem{example}[example]{Example}
\aliascntresetthe{example}
\providecommand*{\exampleautorefname}{Example}

\newaliascnt{remark}{definition}
\newtheorem{remark}[remark]{Remark}
\aliascntresetthe{remark}
\providecommand*{\remarkautorefname}{Remark}

\newaliascnt{construction}{definition}
\newtheorem{construction}[construction]{Construction}
\aliascntresetthe{construction}
\providecommand*{\constructionautorefname}{Construction}

\newaliascnt{convention}{definition}
\newtheorem{convention}[convention]{Convention}
\aliascntresetthe{convention}
\providecommand*{\conventionautorefname}{Convention}

\newaliascnt{theorem}{definition}
\newtheorem{theorem}[theorem]{Theorem}
\aliascntresetthe{theorem}
\providecommand*{\theoremautorefname}{Theorem}

\newaliascnt{lemma}{definition}
\newtheorem{lemma}[lemma]{Lemma}
\aliascntresetthe{lemma}
\providecommand*{\lemmaautorefname}{Lemma}

\newaliascnt{proposition}{definition}
\newtheorem{proposition}[proposition]{Proposition}
\aliascntresetthe{proposition}
\providecommand*{\propositionautorefname}{Proposition}

\newaliascnt{corollary}{definition}
\newtheorem{corollary}[corollary]{Corollary}
\aliascntresetthe{corollary}
\providecommand*{\corollaryautorefname}{Corollary}

\newaliascnt{conjecture}{definition}
\newtheorem{conjecture}[conjecture]{Conjecture}
\aliascntresetthe{conjecture}
\providecommand*{\conjectureautorefname}{Conjecture}

%----------------------------------------------------------------------------------------
%	MACROS & SHORTCUTS (DAG SPECIFIC)
%----------------------------------------------------------------------------------------


% End of Package
\endinput